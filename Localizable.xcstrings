          }
        }
      }
    },
    "searches_for_xccrashpoint_files_matching_the_current_scheme": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sucht .xccrashpoint Dateien passend zum aktuellen Schema, extrahiert die enthaltenen Crash-Dateien und legt sie geordnet im Zielverzeichnis ab."
          }
        },
        "en": {
