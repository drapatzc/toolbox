          }
        }
      }
    },
    "searches_for_try_crash_on_error_and_try_swallows_error_both": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sucht nach try! (Crash bei Fehler) und try? (verschluckt Fehler) — beides sind risikoreiche Muster."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Searches for try! (crash on error) and try? (swallows error) — both are risky patterns."
          }
        }
      }
    },
    "searches_for_urlsession_calls_and_datatask_methods_provides": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sucht nach URLSession-Aufrufen und dataTask-Methoden — gibt einen Überblick über Netzwerkoperationen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Searches for URLSession calls and dataTask methods — provides an overview of network operations."
          }
        }
      }
    },
    "searches_for_var_x_type_implicitly_unwrapped_optionals_can": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sucht nach 'var x: Type!' — Implicitly Unwrapped Optionals können zu Crashes führen wenn sie nil sind."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Searches for 'var x: Type!' — Implicitly Unwrapped Optionals can cause crashes when nil."
          }
        }
      }
    },
    "searches_for_var_x_type_nil_the_default_value_is_already": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sucht nach 'var x: Type? = nil' — der Defaultwert ist bereits nil, die Zuweisung ist redundant."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Searches for 'var x: Type? = nil' — the default value is already nil, the assignment is redundant."
          }
        }
      }
    },
    "searches_for_variable_names_with_only_1_2_characters_except": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sucht nach Variablennamen mit nur 1–2 Zeichen (außer in Loops) — schlechte Lesbarkeit."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Searches for variable names with only 1–2 characters (except in loops) — poor readability."
          }
        }
      }
    },
    "searches_for_variables_with_password_secret_apikey_or_token": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sucht nach Variablen mit 'password', 'secret', 'apiKey' oder 'token' — könnten hardcodierte Zugangsdaten enthalten."
          }
        },
        "en": {
