            "state": "translated",
            "value": "Searches for .xccrashpoint files matching the current scheme, extracts the contained crash files, and stores them in an organized target directory."
          }
        }
      }
    },
    "searches_history_for_commits_adding_removing_term_var": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Durchsucht die Git-History nach Commits, die einen bestimmten Begriff eingeführt oder entfernt haben"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Searches Git history for commits that introduced or removed a specific term"
          }
        }
      }
    },
    "searches_history_for_commits_matching_regex_diff_var": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Durchsucht die Git-History nach Commits, deren Diff auf einen regulären Ausdruck passt"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Searches Git history for commits whose diff matches a regular expression"
          }
        }
      }
    },
    "searches_the_entire_git_history_for_commits_by_a_specific": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Durchsucht die gesamte Git-History nach Commits eines bestimmten Autors (git log --author). Teil-Treffer möglich, z.B. 'Max' findet 'Max Muster'. Zeigt bis zu 50 Commits."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Searches the entire Git history for commits by a specific author (git log --author). Partial matches possible, e.g. 'Max' finds 'Max Muster'. Shows up to 50 commits."
          }
        }
      }
    },
    "searches_the_entire_git_history_for_commits_that_deleted": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sucht in der gesamten Git-History nach Commits, die Dateien gelöscht haben (--diff-filter=D)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Searches the entire Git history for commits that deleted files (--diff-filter=D)."
          }
        }
      }
    },
    "searches_the_entire_git_history_for_commits_whose_message": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Durchsucht die gesamte Git-History nach Commits, deren Nachricht den Suchbegriff enthält (git log --grep). Groß-/Kleinschreibung ignoriert. Zeigt bis zu 50 Treffer."
          }
        },
        "en": {
