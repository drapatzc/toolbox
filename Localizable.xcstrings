          "stringUnit": {
            "state": "translated",
            "value": "Deletes ALL Xcode caches at once: Derived Data, Module Cache, Simulator Cache, SPM Cache and Xcode Caches. Everything will be rebuilt afterwards."
          }
        }
      }
    },
    "deletes_all_xcode_caches_re_resolves_spm_packages_performs": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Löscht alle Xcode-Caches, lädt SPM-Pakete neu, baut die App komplett neu und startet sie im Simulator. Der komplette Reset-Zyklus."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deletes all Xcode caches, re-resolves SPM packages, performs a full rebuild and launches the app in the simulator. The complete reset cycle."
          }
        }
      }
    },
    "deletes_derived_data_module_cache_simulator_cache_and_xcode": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Löscht Derived Data, Module Cache, Simulator Cache und Xcode Caches. SPM Cache bleibt erhalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deletes Derived Data, Module Cache, Simulator Cache and Xcode Caches. SPM Cache is preserved."
          }
        }
      }
    },
    "deletes_internal_xcode_caches_library_caches_com_apple_dt": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Löscht interne Xcode-Caches (~/Library/Caches/com.apple.dt.Xcode) inklusive LLVM- und Indexierungs-Caches."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deletes internal Xcode caches (~/Library/Caches/com.apple.dt.Xcode) including LLVM and indexing caches."
          }
        }
      }
    },
    "deletes_only_deriveddata_and_rebuilds_the_app_completely": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Löscht nur DerivedData und baut die App komplett neu. SPM-Packages bleiben gecacht — deutlich schneller als Full Reset."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deletes only DerivedData and rebuilds the app completely. SPM packages remain cached — much faster than Full Reset."
          }
        }
      }
    },
    "deletes_the_ios_simulator_cache_library_developer": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Löscht den Cache des iOS-Simulators (~/Library/Developer/CoreSimulator/Caches). Behebt Darstellungsfehler und veraltete Simulator-Ressourcen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deletes the iOS Simulator cache (~/Library/Developer/CoreSimulator/Caches). Fixes rendering issues and stale simulator resources."
